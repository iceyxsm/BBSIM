{
  "name": "qalgo",
  "version": "1.0.0",
  "private": true,
  "description": "QALGO — Algorithmic Trading Platform",
  "scripts": {
    "dev:api": "pnpm --filter @qalgo/api dev",
    "dev:app": "pnpm --filter @qalgo/app dev",
    "dev": "pnpm --filter @qalgo/api dev & pnpm --filter @qalgo/app dev",
    "build": "pnpm --filter @qalgo/shared build && pnpm --filter @qalgo/api build && pnpm --filter @qalgo/app build",
    "seed": "pnpm --filter @qalgo/api seed",
    "app": "pnpm --filter @qalgo/app tauri:dev",
    "app:build": "pnpm --filter @qalgo/app tauri:build",
    "bridge": "cd bridge && python server.py"
  }
}
