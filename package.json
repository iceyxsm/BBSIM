{
  "name": "bbsim",
  "version": "1.0.0",
  "private": true,
  "description": "BBSIM — Brokers Book Simulator",
  "scripts": {
    "dev:api": "pnpm --filter @bbsim/api dev",
    "dev:firm": "pnpm --filter @bbsim/firm dev",
    "dev:trader": "pnpm --filter @bbsim/trader dev",
    "dev": "pnpm --filter @bbsim/api dev & pnpm --filter @bbsim/firm dev & pnpm --filter @bbsim/trader dev",
    "build": "pnpm --filter @bbsim/shared build && pnpm --filter @bbsim/api build && pnpm --filter @bbsim/firm build && pnpm --filter @bbsim/trader build",
    "seed": "pnpm --filter @bbsim/api seed",
    "firm": "powershell -ExecutionPolicy Bypass -File scripts/windows/dev-firm.ps1",
    "trader": "powershell -ExecutionPolicy Bypass -File scripts/windows/dev-trader.ps1",
    "all": "powershell -ExecutionPolicy Bypass -File scripts/windows/dev-all.ps1",
    "bridge": "cd bridge && python server.py"
  }
}
